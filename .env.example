# Network Rail Open Data credentials
NROD_USERNAME=your_email@example.com
NROD_PASSWORD=your_nrod_password

# Realtime Trains API (optional)
RTT_TOKEN=your_rtt_refresh_token

# Admin bearer token for protected GET endpoints (/feedback, /admin/db.sqlite.gz)
# AND for the soft-admin debug endpoints (/live, /live/data).
# Generate with `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
# Leave blank to disable strict admin endpoints (they return 503). Soft-admin
# endpoints also return 503 unless ADMIN_NO_AUTH_DEV_ONLY=1 is set below.
ADMIN_TOKEN=

# Local-development opt-in: allow /live and /live/data without ADMIN_TOKEN.
# Set to "1" only for local development. Has no effect once ADMIN_TOKEN is set.
ADMIN_NO_AUTH_DEV_ONLY=
