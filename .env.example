# Network Rail Open Data credentials
NROD_USERNAME=your_email@example.com
NROD_PASSWORD=your_nrod_password

# Realtime Trains API (optional)
RTT_TOKEN=your_rtt_refresh_token

# Admin bearer token for protected GET endpoints (e.g. /feedback, /history details).
# Generate with `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
# Leave blank to disable admin endpoints (they will return 503).
ADMIN_TOKEN=
