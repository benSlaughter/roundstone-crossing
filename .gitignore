# Python virtualenv
.venv/

# Python bytecode
__pycache__/
*.pyc

# Test/coverage artefacts
.pytest_cache/
.coverage
htmlcov/

# Environment variables (secrets)
.env

# SQLite databases (runtime data)
*.db

# macOS
.DS_Store

# Runtime data (but track data/observations/ and data/camera_sites/ metadata)
data/*
!data/observations/
!data/camera_sites/

# Within camera_sites: exclude raw video files, extracted frames,
# detections.csv (large per-frame log), and validation artefacts
# (manifest + JPGs are working data, not source-of-truth)
data/camera_sites/**/*.avi
data/camera_sites/**/*.mp4
data/camera_sites/**/frames/
data/camera_sites/**/validation/
data/camera_sites/**/detections.csv
data/camera_sites/**/quality.json
data/camera_sites/**/quality_report.md

# Log files
logs/

# Python packaging
*.egg-info/
dist/
build/

# IDE files
.idea/
.vscode/

# Node
node_modules/
server.pid

# Experiment runtime data (databases, logs, output, PID files)
experiments/*.db
experiments/*.db-shm
experiments/*.db-wal
experiments/*.jsonl
experiments/*.out
experiments/*.pid

# Experiment directories with large/sensitive data
experiments/images/
experiments/raw_dumps/

# Wiki page dumps (HTML, copyrighted content)
docs/wiki-pages/
